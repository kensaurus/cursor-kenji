#!/bin/sh
# Validate skills + keep derived skill counts in sync on every commit.
# Enable once per clone:  git config core.hooksPath .githooks  (npm run prepare does this)

command -v node >/dev/null 2>&1 || { echo "pre-commit: node not found, skipping checks"; exit 0; }

# 0. Block likely secrets in staged files (fail closed).
if ! node scripts/scan-secrets.mjs; then
  echo "pre-commit: secret scan failed — remove credentials or use placeholders."
  exit 1
fi

# 1. Validate every skill against the Agent Skills spec (blocks on error).
if ! node scripts/validate-skills.mjs; then
  echo "pre-commit: skill validation failed — fix the errors above before committing."
  exit 1
fi

# 2. Keep derived counts in sync (auto-fix + re-stage all touched files, never block).
COUNT_FILES="README.md docs/CATALOG.md docs/PROMOTION.md package.json"
if ! node scripts/check-skill-count.mjs >/dev/null 2>&1; then
  echo "pre-commit: skill count drifted — auto-fixing…"
  node scripts/check-skill-count.mjs --fix
  git add $COUNT_FILES 2>/dev/null || true
  echo "pre-commit: re-staged: $COUNT_FILES"
fi
exit 0
