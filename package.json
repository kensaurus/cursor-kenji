{
  "name": "@kensaurus/cursor-kenji",
  "version": "1.2.1",
  "description": "90 Cursor AI agent skills, 13 slash commands, 5 subagents, and MCP configs for React/Next.js/Supabase development.",
  "type": "module",
  "bin": {
    "cursor-kenji": "./bin/install.mjs"
  },
  "scripts": {
    "install:cursor": "node bin/install.mjs",
    "install:cursor:clean": "node bin/install.mjs --clean",
    "install:cursor:dry": "node bin/install.mjs --dry-run",
    "install:cursor:clean:dry": "node bin/install.mjs --clean --dry-run",
    "install:cursor:link": "node bin/install.mjs --link",
    "install:cursor:restore": "node bin/install.mjs --restore",
    "check:skills": "node scripts/check-skill-count.mjs",
    "fix:skills": "node scripts/check-skill-count.mjs --fix",
    "validate:skills": "node scripts/validate-skills.mjs",
    "test:install": "node scripts/test-install.mjs",
    "test": "node scripts/validate-skills.mjs && node scripts/check-skill-count.mjs && node scripts/test-install.mjs",
    "prepare": "git config core.hooksPath .githooks"
  },
  "keywords": [
    "cursor",
    "cursor-ai",
    "cursor-skills",
    "agent-skills",
    "ai-agents",
    "llm-tools",
    "claude",
    "mcp",
    "nextjs",
    "supabase"
  ],
  "files": [
    "skills/",
    "skills-cursor/",
    "commands/",
    "agents/",
    "rules/",
    "mcp/",
    "install.sh",
    "bin/",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "NOTICE"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kensaurus/cursor-kenji.git"
  },
  "homepage": "https://github.com/kensaurus/cursor-kenji#readme",
  "bugs": {
    "url": "https://github.com/kensaurus/cursor-kenji/issues"
  },
  "author": "kensaurus",
  "license": "MIT"
}
