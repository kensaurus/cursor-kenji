{
  "mcpServers": {

    "sequential-thinking": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-sequential-thinking@2025.12.18"]
    },

    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp@3.2.2"]
    },

    "firecrawl": {
      "command": "npx",
      "args": ["-y", "firecrawl-mcp@3.21.3"],
      "env": {
        "FIRECRAWL_API_KEY": "YOUR_FIRECRAWL_API_KEY"
      }
    },

    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github@2025.4.8"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "YOUR_GITHUB_PAT"
      }
    },

    "supabase": {
      "command": "npx",
      "args": ["-y", "@supabase/mcp-server-supabase@0.8.2", "--project-ref", "YOUR_SUPABASE_PROJECT_REF"],
      "env": {
        "SUPABASE_ACCESS_TOKEN": "YOUR_SUPABASE_ACCESS_TOKEN"
      }
    },

    "chrome-devtools-mcp": {
      "command": "npx",
      "args": ["-y", "chrome-devtools-mcp@1.3.0", "--browser-url=http://127.0.0.1:9222"]
    },

    "playwright": {
      "command": "npx",
      "args": ["-y", "@playwright/mcp@0.0.76", "--viewport-size", "1280x800", "--save-session", "--output-dir", ".playwright-mcp"]
    },

    "postgres": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-postgres@0.6.2"],
      "env": {
        "POSTGRES_CONNECTION_STRING": "postgresql://user:pass@host:5432/dbname"
      }
    },

    "github-official": {
      "command": "docker",
      "args": [
        "run", "-i", "--rm",
        "-e", "GITHUB_PERSONAL_ACCESS_TOKEN",
        "ghcr.io/github/github-mcp-server"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "YOUR_GITHUB_PAT"
      }
    },

    "aws-lambda": {
      "command": "uvx",
      "args": ["awslabs.lambda-tool-mcp-server@2.0.19"],
      "env": {
        "AWS_PROFILE": "default",
        "AWS_REGION": "ap-northeast-1",
        "FASTMCP_LOG_LEVEL": "ERROR"
      }
    },

    "aws-s3": {
      "command": "uvx",
      "args": ["awslabs.aws-api-mcp-server@1.3.45"],
      "env": {
        "AWS_PROFILE": "default",
        "AWS_REGION": "ap-northeast-1",
        "FASTMCP_LOG_LEVEL": "ERROR"
      }
    },

    "aws-cloudwatch": {
      "command": "uvx",
      "args": ["awslabs.cloudwatch-mcp-server@0.0.8"],
      "env": {
        "AWS_PROFILE": "default",
        "AWS_REGION": "ap-northeast-1",
        "FASTMCP_LOG_LEVEL": "ERROR"
      }
    },

    "redis": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-redis@2025.4.25"],
      "env": {
        "REDIS_URL": "redis://localhost:6379"
      }
    },

    "slack": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-slack@2025.4.25"],
      "env": {
        "SLACK_BOT_TOKEN": "YOUR_SLACK_BOT_TOKEN"
      }
    },

    "notion": {
      "command": "npx",
      "args": ["-y", "@notionhq/notion-mcp-server@2.4.1"],
      "env": {
        "NOTION_API_KEY": "YOUR_NOTION_API_KEY"
      }
    },

    "memory": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-memory@2026.1.26"]
    }
  }
}
